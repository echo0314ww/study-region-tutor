# Study Region Tutor - Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit real keys or tokens to version control.
# Runtime precedence: shell/process env > .env.local > .env

# ──────────────────────────────────────────────
# Client-side (Electron app)
# ──────────────────────────────────────────────

# Proxy service URL (optional, overrides built-in default)
# TUTOR_PROXY_URL=http://127.0.0.1:8787

# Proxy access token (required for API proxying)
# TUTOR_PROXY_TOKEN=your-proxy-token-here

# ──────────────────────────────────────────────
# Server-side (proxy-server.mjs)
# ──────────────────────────────────────────────

# Port for the proxy server
TUTOR_PROXY_PORT=8787

# Comma-separated list of token profile names
# TUTOR_PROXY_TOKENS=student_a,student_b,guest

# Per-profile tokens (replace with strong random values)
# TUTOR_PROXY_TOKEN_STUDENT_A=replace-with-random-token
# TUTOR_PROXY_TOKEN_STUDENT_B=replace-with-random-token
# TUTOR_PROXY_TOKEN_GUEST=replace-with-random-token

# Rate limiting
TUTOR_PROXY_RATE_LIMIT_PER_MINUTE=20
TUTOR_PROXY_RATE_LIMIT_BURST=5

# ──────────────────────────────────────────────
# AI Provider Configuration (direct mode)
# ──────────────────────────────────────────────

# Provider list (comma-separated IDs)
# AI_PROVIDERS=openai

# Default provider
# AI_DEFAULT_PROVIDER=openai

# Provider-specific settings (replace 'OPENAI' with your provider ID in uppercase)
# AI_PROVIDER_OPENAI_NAME=OpenAI
# AI_PROVIDER_OPENAI_BASE_URL=https://api.openai.com/v1
# AI_PROVIDER_OPENAI_API_TYPE=openai-compatible
# AI_PROVIDER_OPENAI_API_MODE=chat-completions
# AI_PROVIDER_OPENAI_API_KEY=sk-your-api-key-here
