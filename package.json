{
  "name": "study-region-tutor",
  "version": "1.4.0",
  "description": "A cross-platform desktop study assistant that explains selected screen regions.",
  "main": "out/main/index.js",
  "author": "Study Region Tutor Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/echo0314ww/study-region-tutor.git"
  },
  "homepage": "https://github.com/echo0314ww/study-region-tutor#readme",
  "bugs": {
    "url": "https://github.com/echo0314ww/study-region-tutor/issues"
  },
  "keywords": [
    "electron",
    "study",
    "tutor",
    "ocr",
    "screen-capture",
    "ai"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:tabs": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/open-dev-tabs.ps1",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "docs:check": "node scripts/check-docs.mjs",
    "security:check": "node scripts/check-security-boundaries.mjs",
    "validate": "npm run typecheck && npm run lint && npm run test && npm run docs:check && npm run security:check",
    "build": "electron-vite build",
    "proxy:dev": "node server/proxy-server.mjs",
    "proxy:check": "node --check server/proxy-server.mjs && node --check server/runtime-env.mjs",
    "ngrok:dev": "node server/ngrok-dev.mjs",
    "dist": "npm run build && electron-builder --win nsis",
    "publish:win": "npm run build && electron-builder --win nsis --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "katex": "^0.16.45",
    "pngjs": "^7.0.0",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/utils": "^3.0.0",
    "@types/katex": "^0.16.8",
    "@types/node": "^22.10.2",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^2.1.9",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  },
  "build": {
    "appId": "com.studyregion.tutor",
    "productName": "Study Region Tutor",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "echo0314ww",
        "repo": "study-region-tutor",
        "releaseType": "release"
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Study-Region-Tutor-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "${productName}"
    }
  }
}
