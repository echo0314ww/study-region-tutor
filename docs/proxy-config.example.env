# Copy selected entries into .env.local. Never commit real keys or tokens.
# Runtime precedence is: shell/process environment > .env.local > .env.

AI_PROVIDERS=makelove
AI_DEFAULT_PROVIDER=makelove

AI_PROVIDER_MAKELOVE_NAME=Makelove
AI_PROVIDER_MAKELOVE_BASE_URL=https://your-makelove-endpoint/v1
AI_PROVIDER_MAKELOVE_API_TYPE=openai-compatible
AI_PROVIDER_MAKELOVE_API_MODE=chat-completions
AI_PROVIDER_MAKELOVE_API_KEY=replace-with-provider-key

# Use these instead when the provider exposes Gemini or Anthropic native protocols.
# AI_PROVIDER_MAKELOVE_API_TYPE=gemini
# AI_PROVIDER_MAKELOVE_BASE_URL=https://your-makelove-endpoint/v1beta
# AI_PROVIDER_MAKELOVE_API_TYPE=anthropic
# AI_PROVIDER_MAKELOVE_BASE_URL=https://your-makelove-endpoint/v1

TUTOR_PROXY_PORT=8787
TUTOR_PROXY_URL=http://127.0.0.1:8787

TUTOR_PROXY_TOKENS=student_a,student_b,guest,admin
TUTOR_PROXY_TOKEN_STUDENT_A=replace-with-random-token
TUTOR_PROXY_TOKEN_STUDENT_B=replace-with-random-token
TUTOR_PROXY_TOKEN_GUEST=replace-with-random-token
TUTOR_PROXY_TOKEN_ADMIN=replace-with-random-token

TUTOR_PROXY_RATE_LIMIT_PER_MINUTE=20
TUTOR_PROXY_RATE_LIMIT_BURST=5
TUTOR_PROXY_RATE_LIMIT_GUEST_PER_MINUTE=8
TUTOR_PROXY_RATE_LIMIT_GUEST_BURST=2
TUTOR_PROXY_RATE_LIMIT_ADMIN_PER_MINUTE=60
TUTOR_PROXY_RATE_LIMIT_ADMIN_BURST=15
